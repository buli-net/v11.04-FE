<?xml version="1.0" encoding="utf-8"?>
<!-- Paper Wallet creation screen -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground">

    <LinearLayout
        android:id="@+id/paper_wallet_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Security warning banner -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/paper_wallet_warning"
            android:textAppearance="?android:attr/textAppearanceSmall"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginBottom="16dp" />

        <!-- ========== Public section ========== -->
        <TextView
            android:id="@+id/paper_wallet_public_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/paper_wallet_public_label"
            android:textAppearance="?android:attr/textAppearanceMedium"
            android:textColor="?android:attr/textColorPrimary" />

        <!-- QR code for the public address/hex -->
        <ImageView
            android:id="@+id/paper_wallet_qr_address"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_gravity="center"
            android:layout_marginTop="8dp"
            android:background="#ffffff"
            android:padding="8dp" />

        <!-- Text representation of the public address/hex -->
        <TextView
            android:id="@+id/paper_wallet_address"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textIsSelectable="true"
            android:textColor="?android:attr/textColorPrimary"
            android:gravity="center"
            android:layout_marginTop="8dp" />

        <!-- Public actions: Copy / Format toggle / Hide -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/paper_wallet_copy_address"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="@string/paper_wallet_copy" />

            <Button
                android:id="@+id/paper_wallet_public_format"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="@string/paper_wallet_public_format_bech32" />

            <Button
                android:id="@+id/paper_wallet_toggle_address"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="@string/paper_wallet_hide" />
        </LinearLayout>

        <!-- Divider between public and private sections -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?android:attr/listDivider"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp" />

        <!-- ========== Private key section ========== -->
        <TextView
            android:id="@+id/paper_wallet_key_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/paper_wallet_private_label"
            android:textAppearance="?android:attr/textAppearanceMedium"
            android:textColor="?android:attr/textColorPrimary" />

        <!-- QR code for the private key -->
        <ImageView
            android:id="@+id/paper_wallet_qr_key"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_gravity="center"
            android:layout_marginTop="8dp"
            android:background="#ffffff"
            android:padding="8dp" />

        <!-- Text representation of the private key -->
        <TextView
            android:id="@+id/paper_wallet_key"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textIsSelectable="true"
            android:textColor="?android:attr/textColorPrimary"
            android:gravity="center"
            android:layout_marginTop="8dp" />

        <!-- Private key actions: Copy / Format toggle / Hide -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/paper_wallet_copy_privkey"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="@string/paper_wallet_copy" />

            <Button
                android:id="@+id/paper_wallet_privkey_format"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="@string/paper_wallet_private_format_wif" />

            <Button
                android:id="@+id/paper_wallet_toggle_key"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="@string/paper_wallet_hide_key" />
        </LinearLayout>

        <!-- ========== BIP38 encryption options ========== -->
        <CheckBox
            android:id="@+id/paper_wallet_encrypt_toggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/paper_wallet_encrypt_bip38"
            android:textColor="?android:attr/textColorPrimary"
            android:layout_marginTop="12dp" />

        <CheckBox
            android:id="@+id/paper_wallet_show_pass"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/paper_wallet_show"
            android:textColor="?android:attr/textColorPrimary"
            android:visibility="gone" />

        <EditText
            android:id="@+id/paper_wallet_passphrase"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/paper_wallet_passphrase"
            android:inputType="textPassword"
            android:enabled="false"
            android:visibility="gone" />

        <EditText
            android:id="@+id/paper_wallet_passphrase_confirm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/paper_wallet_passphrase_confirm"
            android:inputType="textPassword"
            android:enabled="false"
            android:visibility="gone" />

        <TextView
            android:id="@+id/paper_wallet_bip38_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/paper_wallet_bip38_hint"
            android:textAppearance="?android:attr/textAppearanceSmall"
            android:textColor="?android:attr/textColorSecondary"
            android:visibility="gone" />

        <!-- Divider before action buttons -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?android:attr/listDivider"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp" />

        <!-- ========== Action buttons ========== -->
        <Button
            android:id="@+id/paper_wallet_generate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/paper_wallet_generate_new" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/paper_wallet_save"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="@string/paper_wallet_save" />

            <Button
                android:id="@+id/paper_wallet_share"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="@string/paper_wallet_share" />

            <Button
                android:id="@+id/paper_wallet_print"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="@string/paper_wallet_print" />

            <Button
                android:id="@+id/paper_wallet_export_txt"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="@string/paper_wallet_export_txt" />
        </LinearLayout>
    </LinearLayout> 
        
</ScrollView>
