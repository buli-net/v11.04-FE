<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/tx_page_bg">

    <!-- HEADER -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="2dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="@color/tx_card_bg"
        android:layout_margin="8dp"
        android:layout_marginBottom="4dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <ImageView android:id="@+id/iv_tx_qr"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:scaleType="fitCenter"
                android:padding="4dp"
                android:background="@drawable/bg_qr_white_rounded"
                android:clipToOutline="true"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/tx_details_qr_desc" />

            <TextView android:id="@+id/tv_direction"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@id/iv_tx_qr"
                android:layout_marginEnd="12dp"
                android:textStyle="bold"
                android:textSize="28sp"
                android:textColor="@color/tx_text_primary"
                android:fontFamily="sans-serif-medium" />

            <TextView android:id="@+id/tv_amount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/tv_direction"
                android:layout_alignStart="@id/tv_direction"
                android:layout_toStartOf="@id/iv_tx_qr"
                android:layout_marginTop="4dp"
                android:textSize="28sp"
                android:textStyle="bold" />
        </RelativeLayout>
    </androidx.cardview.widget.CardView>

    <!-- NỘI DUNG CUỘN -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- dán nguyên phần từ dòng 200 của mày trở xuống vào đây -->
            <!-- ví dụ: CardView Received details, CardView Transaction ID... -->
            <!-- ... giữ nguyên tất cả các view có id tv_to, tv_txid, tv_txid_copy ... -->

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
